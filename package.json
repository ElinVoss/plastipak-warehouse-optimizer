{
  "name": "warehouse-optimizer",
  "version": "2.4.3",
  "private": true,
  "description": "Warehouse Optimizer (Vite + React + Electron) — tunnel-aware consolidation + putaway finder",
  "author": "",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "node scripts\\vite-with-esbuild.mjs",
    "patch": "concurrently -k \"node scripts\\vite-with-esbuild.mjs\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "node scripts\\vite-with-esbuild.mjs build",
    "preview": "node scripts\\vite-with-esbuild.mjs preview",
    "pack": "npm run dist",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis",
    "installer": "npm run dist:win"
  },
  "dependencies": {
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.541.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^7.3.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.warehouse.optimizer",
    "productName": "Warehouse Optimizer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "^0.27.3"
  }
}
